set folder = "~/Documents/mail/account-private/"
unmailboxes *
set spoolfile = "+INBOX"
unset record # outlook and gmail auto saves sent to here
set trash = "+已删除邮件" # delete mails will be saved to here
set postponed = "+草稿箱"
mailboxes "=INBOX" "=草稿箱" "=已发送邮件" "=垃圾邮件" "=已删除邮件" 

